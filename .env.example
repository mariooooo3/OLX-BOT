# ---- OLX ----
# NEFOLOSITE de bot — pastrate doar pentru compatibilitate. Login-ul e
# 100% manual, prin fereastra de browser deschisa de login.py / dashboard
# (OLX are CAPTCHA anti-bot, deci nu se poate automatiza). Nu completa aici.
OLX_EMAIL=
OLX_PASSWORD=

# ---- LLM ----
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant

# ---- bot ----
POLL_INTERVAL_SECONDS=45
LOG_LEVEL=INFO

# ---- MVP2: alegerea adaptoarelor (schimbi doar aici, zero cod) ----
# LLM: groq (implicit) | ollama
LLM_BACKEND=groq
# stocare: json (implicit) | db
STORAGE_BACKEND=json
# folosit doar cand STORAGE_BACKEND=db
DATABASE_URL=sqlite:///data/olxbot.db
# coada de joburi + workeri separati (necesita STORAGE_BACKEND=db)
USE_QUEUE=false

# ---- Ollama (doar cand LLM_BACKEND=ollama) ----
OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434
